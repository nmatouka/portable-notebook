{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mnote Player",
  "version": "0.1.0",
  "identifier": "app.mnote.player",
  "build": {
    "frontendDist": "../placeholder-dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "fileAssociations": [
      {
        "ext": ["mnote"],
        "name": "marimo notebook",
        "description": "Portable marimo notebook",
        "role": "Viewer"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
